# .gitignore - Archivos a ignorar en Git

# Entorno virtual
venv/
env/
.venv
ENV/

# Variables de entorno
.env
.env.local
.env.*.local

# Base de datos
*.db
*.sqlite
*.sqlite3
*.psycopg

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Logs
*.log
/var/log/
logs/

# Backups
backups/
*.backup
*.bak
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.swp
*.swo
*.iml
.DS_Store

# Node (si usas webpack o similar)
node_modules/
npm-debug.log

# Certificados
*.pem
*.key
*.crt
certs/

# Archivos temporales
tmp/
temp/
.cache/

# Uploads (opcional, si tienes)
uploads/
media/

# Tests
.pytest_cache/
.coverage
htmlcov/

# Docker
.dockerignore

# Miscellaneous
.env.production
.env.staging
