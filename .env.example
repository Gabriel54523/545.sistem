# ============================================================================
# Variables de Entorno - Sistema de Inventario
# ============================================================================
# INSTRUCCIONES:
#   1. Copiar este archivo: cp .env.example .env
#   2. Editar valores según tu entorno
#   3. NUNCA commit el archivo .env a Git
# ============================================================================

# ──── APLICACIÓN ────
# Modo: development | production
FLASK_ENV=development
FLASK_DEBUG=0

# Clave secreta (generar con: python3 -c "import os; print(os.urandom(32).hex())")
# OBLIGATORIO en producción
SECRET_KEY=dev-key-change-this-in-production

# ──── BASE DE DATOS (Desarrollo con SQLite) ────
# No necesita configuración - usa inventario.db por defecto

# ──── BASE DE DATOS (Producción con PostgreSQL) ────
# Descomenta y configura si usas PostgreSQL en producción
# DB_USER=inventario
# DB_PASSWORD=tu_password_muy_segura
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=inventario_db

# Alternativa: URL de conexión directa
# DATABASE_URL=postgresql://usuario:password@host:5432/inventario_db

# ──── LOGGING ────
LOG_LEVEL=INFO
LOG_FILE=/var/log/inventario/app.log

# ──── SEGURIDAD (Producción) ────
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_HTTPONLY=true
# REMEMBER_COOKIE_SECURE=true
